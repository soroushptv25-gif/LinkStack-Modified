<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!--
        Record rules for digital.business.card.

        Regular users may only see and manage their OWN cards (matched on the
        owner field). System administrators see all cards. The public website
        page reads cards with sudo(), so it is unaffected by these rules.
    -->
    <record id="dbc_rule_user_own" model="ir.rule">
        <field name="name">Business cards: own records only</field>
        <field name="model_id" ref="model_digital_business_card"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="dbc_rule_admin_all" model="ir.rule">
        <field name="name">Business cards: administrators see all</field>
        <field name="model_id" ref="model_digital_business_card"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

</odoo>
