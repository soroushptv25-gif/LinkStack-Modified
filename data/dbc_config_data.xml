<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Default generation mode is MANUAL (no auto-creation of employee cards).
         noupdate so an admin's later choice is never overwritten on upgrade. -->
    <data noupdate="1">
        <record id="param_auto_generate" model="ir.config_parameter">
            <field name="key">digital_business_card.auto_generate</field>
            <field name="value">false</field>
        </record>
    </data>
</odoo>
