<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <menuitem id="menu_dbc_root"
              name="Business Cards"
              sequence="90"/>

    <menuitem id="menu_dbc_cards"
              name="Cards"
              parent="menu_dbc_root"
              action="action_dbc"
              sequence="10"/>

    <!-- Employees who still need a card (works even when auto-generation is off). -->
    <menuitem id="menu_dbc_emp_no_card"
              name="Employees without a Card"
              parent="menu_dbc_root"
              action="action_emp_no_card"
              sequence="15"/>

    <!-- Data sources hold server credentials, so admins only. -->
    <menuitem id="menu_dbc_sources"
              name="Data Sources"
              parent="menu_dbc_root"
              action="action_dbc_source"
              groups="base.group_system"
              sequence="20"/>

    <!-- Publish targets hold upload credentials, so admins only. -->
    <menuitem id="menu_dbc_targets"
              name="Publish Targets"
              parent="menu_dbc_root"
              action="action_dbc_target"
              groups="base.group_system"
              sequence="30"/>

    <!-- Manual/automatic generation settings, admins only. -->
    <menuitem id="menu_dbc_config"
              name="Card Generation"
              parent="menu_dbc_root"
              action="action_dbc_config"
              groups="base.group_system"
              sequence="40"/>

</odoo>
