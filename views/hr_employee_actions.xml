<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        "Create Business Card" appears in the Employees app under Actions when
        one or more employees are selected (or on the employee form). It makes
        a card per employee and opens the result.
    -->
    <record id="action_emp_create_card" model="ir.actions.server">
        <field name="name">Create Business Card</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="binding_model_id" ref="hr.model_hr_employee"/>
        <field name="binding_view_types">tree,form</field>
        <field name="state">code</field>
        <field name="code">
cards = env['digital.business.card'].create_for_employees(records)
action = {
    'type': 'ir.actions.act_window',
    'name': 'Business Cards',
    'res_model': 'digital.business.card',
    'view_mode': 'tree,form',
    'domain': [('id', 'in', cards.ids)],
}
        </field>
    </record>

    <!--
        "Generate" on the Cards list Actions menu: create a card for every
        employee that doesn't have one yet (ignores the current selection),
        then show the newly generated cards.
    -->
    <record id="action_generate_missing_cards" model="ir.actions.server">
        <field name="name">Generate</field>
        <field name="model_id" ref="model_digital_business_card"/>
        <field name="binding_model_id" ref="model_digital_business_card"/>
        <field name="binding_view_types">tree,form</field>
        <field name="state">code</field>
        <field name="code">
employees = env['hr.employee'].search([('has_business_card', '=', False)])
cards = env['digital.business.card'].create_for_employees(employees)
action = {
    'type': 'ir.actions.act_window',
    'name': 'Generated Cards' if cards else 'Business Cards',
    'res_model': 'digital.business.card',
    'view_mode': 'tree,form',
    'domain': [('id', 'in', cards.ids)] if cards else [],
}
        </field>
    </record>

</odoo>
