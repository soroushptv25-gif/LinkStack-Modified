<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Public, no-login card page served at /card/<slug>. -->
    <template id="card_public_page" name="Digital Business Card">&lt;!DOCTYPE html&gt;
        <html>
            <head>
                <meta charset="utf-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1"/>
                <title t-out="card.name"/>
                <link rel="stylesheet" type="text/css"
                      href="/digital_business_card/static/src/css/card.css"/>
                <!-- When the owner designed a custom page, pull Odoo's frontend
                     CSS so editor blocks (columns, spacing, etc.) render right. -->
                <t t-if="card.source_html">
                    <t t-call-assets="web.assets_frontend" t-js="false"/>
                </t>
            </head>
            <body t-attf-class="dbc-theme-#{card.card_template or 'classic'}">
                <t t-if="card.source_html">
                    <!-- Card built from imported HTML: render exactly as given. -->
                    <t t-out="card.source_html"/>
                </t>
                <t t-else="">
                    <div class="dbc-card">
                        <img t-if="card.contact_image" class="dbc-photo"
                             t-attf-src="/web/image/digital.business.card/#{card.id}/contact_image"/>
                        <h1 class="dbc-name" t-out="card.contact_name"/>
                        <p class="dbc-role">
                            <t t-out="card.contact_job_title"/>
                            <t t-if="card.contact_job_title and card.contact_company"> · </t>
                            <t t-out="card.contact_company"/>
                        </p>
                        <p t-if="card.bio" class="dbc-bio" t-out="card.bio"/>

                        <div class="dbc-contacts">
                            <a t-if="card.contact_email" t-attf-href="mailto:#{card.contact_email}"
                               class="dbc-link">✉ <t t-out="card.contact_email"/></a>
                            <a t-if="card.contact_phone" t-attf-href="tel:#{card.contact_phone}"
                               class="dbc-link">☎ <t t-out="card.contact_phone"/></a>
                            <a t-if="card.website_url" t-att-href="card.website_url"
                               class="dbc-link" target="_blank" rel="noopener noreferrer">
                               🌐 <t t-out="card.contact_website"/></a>
                        </div>

                        <a class="dbc-link dbc-vcard" t-attf-href="/card/#{card.access_token}/vcard">
                           👤 Import to contact</a>
                    </div>
                </t>
            </body>
        </html>
    </template>

</odoo>
