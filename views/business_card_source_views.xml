<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_dbc_source_list" model="ir.ui.view">
        <field name="name">digital.business.card.source.list</field>
        <field name="model">digital.business.card.source</field>
        <field name="arch" type="xml">
            <list string="Data Sources">
                <field name="name"/>
                <field name="db_host"/>
                <field name="db_name"/>
                <field name="last_sync"/>
                <field name="last_count"/>
            </list>
        </field>
    </record>

    <record id="view_dbc_source_form" model="ir.ui.view">
        <field name="name">digital.business.card.source.form</field>
        <field name="model">digital.business.card.source</field>
        <field name="arch" type="xml">
            <form string="Data Source">
                <header>
                    <button name="action_test_connection" type="object"
                            string="Test Connection"/>
                    <button name="action_import_cards" type="object"
                            string="Import Cards" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. LinkStack server"/></h1>
                    </div>
                    <group>
                        <field name="active"/>
                    </group>

                    <group string="PostgreSQL Connection">
                        <group>
                            <field name="db_host"/>
                            <field name="db_port"/>
                            <field name="db_name"/>
                        </group>
                        <group>
                            <field name="db_user"/>
                            <field name="db_password" password="True"/>
                        </group>
                        <group>
                            <field name="db_table"/>
                            <field name="col_slug"/>
                            <field name="col_html"/>
                            <field name="col_name"/>
                            <field name="row_limit"/>
                        </group>
                    </group>

                    <group string="Last Import">
                        <field name="last_sync"/>
                        <field name="last_count"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dbc_source" model="ir.actions.act_window">
        <field name="name">Data Sources</field>
        <field name="res_model">digital.business.card.source</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
