<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ Publish target (3rd-party host) ============ -->
    <record id="view_dbc_target_list" model="ir.ui.view">
        <field name="name">digital.business.card.target.list</field>
        <field name="model">digital.business.card.target</field>
        <field name="arch" type="xml">
            <list string="Publish Targets">
                <field name="name"/>
                <field name="url"/>
                <field name="http_method"/>
                <field name="payload_format"/>
            </list>
        </field>
    </record>

    <record id="view_dbc_target_form" model="ir.ui.view">
        <field name="name">digital.business.card.target.form</field>
        <field name="model">digital.business.card.target</field>
        <field name="arch" type="xml">
            <form string="Publish Target">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Company card host"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="url" placeholder="https://cards.example.com/api/upload"/>
                            <field name="http_method"/>
                            <field name="payload_format"/>
                        </group>
                        <group>
                            <field name="auth_token" password="True"/>
                            <field name="allow_private"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dbc_target" model="ir.actions.act_window">
        <field name="name">Publish Targets</field>
        <field name="res_model">digital.business.card.target</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ============ Publish wizard ============ -->
    <record id="view_dbc_publish_wizard_form" model="ir.ui.view">
        <field name="name">digital.business.card.publish.wizard.form</field>
        <field name="model">digital.business.card.publish.wizard</field>
        <field name="arch" type="xml">
            <form string="Publish Business Cards">
                <group>
                    <field name="target_id"/>
                </group>
                <separator string="Cards to publish"/>
                <field name="card_ids">
                    <list>
                        <field name="name"/>
                        <field name="slug"/>
                        <field name="last_published"/>
                    </list>
                </field>
                <footer>
                    <button name="action_publish" type="object"
                            string="Send" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Bound to the Cards list: appears under Actions when rows are ticked. -->
    <record id="action_dbc_publish_wizard" model="ir.actions.act_window">
        <field name="name">Publish to Web</field>
        <field name="res_model">digital.business.card.publish.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_digital_business_card"/>
        <field name="binding_view_types">list,form</field>
    </record>

</odoo>
