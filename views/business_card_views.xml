<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_dbc_list" model="ir.ui.view">
        <field name="name">digital.business.card.list</field>
        <field name="model">digital.business.card</field>
        <field name="arch" type="xml">
            <tree string="Business Cards" decoration-muted="state == 'draft'"
                  decoration-danger="state == 'deactivated'">
                <field name="contact_name" string="Name"/>
                <field name="employee_id" optional="show"/>
                <field name="contact_job_title" string="Position"/>
                <field name="contact_company" string="Company"/>
                <field name="state" string="Status" widget="badge"
                       decoration-success="state == 'published'"
                       decoration-warning="state == 'deactivated'"/>
                <field name="public_url" string="Link" optional="show"/>
                <field name="slug" optional="hide"/>
                <field name="user_id" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_dbc_form" model="ir.ui.view">
        <field name="name">digital.business.card.form</field>
        <field name="model">digital.business.card</field>
        <field name="arch" type="xml">
            <form string="Business Card">
                <header>
                    <!-- Draft -> Published creates the link + QR; Deactivate switches it off. -->
                    <button name="action_publish" type="object" string="Publish"
                            class="btn-primary" invisible="state == 'published'"/>
                    <button name="action_deactivate" type="object" string="Deactivate"
                            invisible="state != 'published'"/>
                    <button name="action_set_draft" type="object" string="Reset to Draft"
                            invisible="state == 'draft'"/>
                    <button name="action_update_from_employee" type="object"
                            string="Update from Employee" invisible="not employee_id"/>
                    <button name="action_download_qr" type="object" string="Download QR"
                            invisible="state != 'published'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,published,deactivated"/>
                </header>
                <sheet>
                    <field name="contact_image" widget="image" class="oe_avatar" readonly="1"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Jane Doe"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="slug"/>
                            <field name="user_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <!-- Editable per-card details. Each field overrides the linked
                         employee's value; leave blank to use the employee's. -->
                    <group string="Profile (edit to override the employee's value)">
                        <group>
                            <field name="job_title" string="Position"
                                   placeholder="e.g. Intern"/>
                            <field name="company"/>
                            <field name="photo" widget="image"/>
                        </group>
                        <group>
                            <field name="email" widget="email"
                                   placeholder="leave blank to use the employee's"/>
                            <field name="phone" widget="phone"
                                   placeholder="leave blank to use the employee's"/>
                            <field name="website" widget="url"/>
                        </group>
                    </group>
                    <!-- What the public card actually shows (effective values). -->
                    <group string="Shown on the card" invisible="not employee_id">
                        <field name="contact_job_title" string="Position"/>
                        <field name="contact_email" string="Email"/>
                        <field name="contact_phone" string="Phone"/>
                    </group>
                    <group string="Draft" invisible="state != 'draft'">
                        <div colspan="2">This card shows the name only. Click
                            <b>Publish</b> (top-left) to create its link and QR code.</div>
                    </group>
                    <group string="Deactivated" invisible="state != 'deactivated'">
                        <div colspan="2">The link and QR are switched off — the public
                            page returns "not found". Click <b>Publish</b> to switch it
                            back on (the same link is reused).</div>
                    </group>
                    <group string="Sharing" invisible="state != 'published'">
                        <field name="slug" readonly="1"/>
                        <field name="public_url" widget="CopyClipboardChar"/>
                        <field name="qr_code" widget="image" options="{'size': [180, 180]}"/>
                        <field name="last_published"/>
                        <field name="published_url" widget="url" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Bio">
                            <field name="bio" placeholder="A short introduction…"/>
                        </page>
                        <page string="Custom HTML">
                            <field name="source_html"
                                   placeholder="Optional. When set, the public page renders this HTML verbatim."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dbc" model="ir.actions.act_window">
        <field name="name">Business Cards</field>
        <field name="res_model">digital.business.card</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
