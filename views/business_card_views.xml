<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_dbc_list" model="ir.ui.view">
        <field name="name">digital.business.card.list</field>
        <field name="model">digital.business.card</field>
        <field name="arch" type="xml">
            <tree string="Business Cards" decoration-muted="state == 'draft'"
                  decoration-danger="state == 'deactivated'">
                <field name="contact_name" string="Name"/>
                <field name="employee_id" optional="show"/>
                <field name="contact_job_title" string="Position"/>
                <field name="contact_company" string="Company"/>
                <field name="state" string="Status" widget="badge"
                       decoration-success="state == 'published'"
                       decoration-warning="state == 'deactivated'"/>
                <field name="public_url" string="Link" optional="show"/>
                <field name="slug" optional="hide"/>
                <field name="user_id" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_dbc_form" model="ir.ui.view">
        <field name="name">digital.business.card.form</field>
        <field name="model">digital.business.card</field>
        <field name="arch" type="xml">
            <form string="Business Card">
                <header>
                    <button name="action_publish" type="object" string="Publish"
                            class="btn-primary" invisible="state == 'published'"/>
                    <button name="action_deactivate" type="object" string="Deactivate"
                            invisible="state != 'published'"/>
                    <button name="action_set_draft" type="object" string="Reset to Draft"
                            invisible="state == 'draft'"/>
                    <button name="action_update_from_employee" type="object"
                            string="Update from Employee" invisible="not employee_id"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,published,deactivated"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Deactivated" bg_color="text-bg-danger"
                            invisible="state != 'deactivated'"/>
                    <widget name="web_ribbon" title="Draft" bg_color="text-bg-secondary"
                            invisible="state != 'draft'"/>

                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_public" type="object" class="oe_stat_button"
                                icon="fa-globe" invisible="state != 'published'">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Public</span>
                                <span class="o_stat_text">Page</span>
                            </div>
                        </button>
                        <button name="action_download_qr" type="object" class="oe_stat_button"
                                icon="fa-qrcode" invisible="state != 'published'">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Download</span>
                                <span class="o_stat_text">QR</span>
                            </div>
                        </button>
                    </div>

                    <field name="contact_image" widget="image" class="oe_avatar" readonly="1"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Jane Doe"/></h1>
                        <h3 class="text-muted d-flex gap-1">
                            <field name="contact_job_title" readonly="1" nolabel="1"/>
                            <span invisible="not contact_job_title or not contact_company">·</span>
                            <field name="contact_company" readonly="1" nolabel="1"/>
                        </h3>
                    </div>

                    <div class="alert alert-info" role="alert" invisible="state != 'draft'">
                        This card shows the <b>name only</b>. Click <b>Publish</b> to create
                        its link and QR code.
                    </div>
                    <div class="alert alert-warning" role="alert" invisible="state != 'deactivated'">
                        The link and QR are <b>switched off</b> (the public page returns
                        "not found"). Click <b>Publish</b> to switch them back on — the same
                        link is reused.
                    </div>

                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="slug" string="Card Link" readonly="1"/>
                        </group>
                        <group>
                            <field name="user_id"/>
                            <field name="active"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Profile" name="profile">
                            <div class="text-muted mb-3" invisible="not employee_id">
                                <i class="fa fa-info-circle me-1"/>Leave a field blank to use
                                the employee's value; fill it to override.
                            </div>
                            <group>
                                <group string="Details">
                                    <field name="job_title" string="Position"
                                           placeholder="e.g. Intern"/>
                                    <field name="company"/>
                                    <field name="email" widget="email"
                                           placeholder="leave blank to use the employee's"/>
                                    <field name="phone" widget="phone"
                                           placeholder="leave blank to use the employee's"/>
                                    <field name="website" widget="url"/>
                                </group>
                                <group string="Photo">
                                    <field name="photo" widget="image" nolabel="1"
                                           class="oe_avatar"/>
                                </group>
                            </group>
                        </page>
                        <page string="Shown on the card" name="shown" invisible="not employee_id">
                            <group col="1">
                                <field name="contact_job_title" string="Position" readonly="1"/>
                                <field name="contact_company" string="Company" readonly="1"/>
                                <field name="contact_email" string="Email" readonly="1"/>
                                <field name="contact_phone" string="Phone" readonly="1"/>
                                <field name="contact_website" string="Website" readonly="1"/>
                            </group>
                        </page>
                        <page string="Sharing" name="sharing" invisible="state != 'published'">
                            <group>
                                <group>
                                    <field name="public_url" widget="CopyClipboardChar"/>
                                    <field name="last_published"/>
                                    <field name="published_url" widget="url" readonly="1"/>
                                </group>
                                <group>
                                    <field name="qr_code" widget="image"
                                           options="{'size': [200, 200]}"/>
                                </group>
                            </group>
                        </page>
                        <page string="Bio" name="bio">
                            <field name="bio" placeholder="A short introduction…"/>
                        </page>
                        <page string="Custom HTML" name="html">
                            <field name="source_html"
                                   placeholder="Optional. When set, the public page renders this HTML verbatim."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_dbc_search" model="ir.ui.view">
        <field name="name">digital.business.card.search</field>
        <field name="model">digital.business.card</field>
        <field name="arch" type="xml">
            <search string="Business Cards">
                <field name="contact_name" string="Name"
                       filter_domain="['|', '|', ('name', 'ilike', self), ('slug', 'ilike', self), ('employee_id.name', 'ilike', self)]"/>
                <field name="employee_id"/>
                <field name="contact_company" string="Company"/>
                <field name="contact_job_title" string="Position"/>
                <field name="slug"/>
                <separator/>
                <filter name="f_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="f_published" string="Published" domain="[('state', '=', 'published')]"/>
                <filter name="f_deactivated" string="Deactivated" domain="[('state', '=', 'deactivated')]"/>
                <separator/>
                <filter name="f_my" string="My Cards" domain="[('user_id', '=', uid)]"/>
                <filter name="f_employee" string="Linked to Employee" domain="[('employee_id', '!=', False)]"/>
                <group expand="0" string="Group By">
                    <filter name="g_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="g_employee" string="Employee" context="{'group_by': 'employee_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_dbc_kanban" model="ir.ui.view">
        <field name="name">digital.business.card.kanban</field>
        <field name="model">digital.business.card</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" sample="1">
                <field name="state"/>
                <field name="public_url"/>
                <field name="contact_image"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record_has_image_fill">
                            <div class="o_kanban_record_top mb-2">
                                <img class="o_image_40_cover rounded me-2"
                                     t-att-src="kanban_image('digital.business.card', 'contact_image', record.id.raw_value)"
                                     alt="Photo"/>
                                <div class="o_kanban_record_headings flex-grow-1">
                                    <strong class="o_kanban_record_title">
                                        <field name="contact_name"/>
                                    </strong>
                                    <div class="text-muted" t-if="record.contact_job_title.raw_value">
                                        <field name="contact_job_title"/>
                                    </div>
                                    <div class="text-muted" t-if="record.contact_company.raw_value">
                                        <field name="contact_company"/>
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="state" widget="label_selection"
                                           options="{'classes': {'draft': 'secondary', 'published': 'success', 'deactivated': 'danger'}}"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <a t-if="record.public_url.raw_value"
                                       t-att-href="record.public_url.value" target="_blank"
                                       title="Open public page" onclick="event.stopPropagation()">
                                        <i class="fa fa-external-link"/>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_dbc" model="ir.actions.act_window">
        <field name="name">Business Cards</field>
        <field name="res_model">digital.business.card</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_dbc_search"/>
    </record>

</odoo>
